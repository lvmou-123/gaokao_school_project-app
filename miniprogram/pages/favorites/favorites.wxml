<view class="favorites-page">
  <view class="page-header">
    <text class="page-title">我的收藏</text>
    <text class="page-subtitle" wx:if="{{total > 0}}">共收藏 {{total}} 所院校</text>
  </view>

  <view class="list-wrap" wx:if="{{!loading}}">
    <view class="empty-state" wx:if="{{list.length === 0}}">
      <view class="empty-icon">💔</view>
      <text class="empty-text">还没有收藏任何院校</text>
      <view class="btn-primary" bindtap="goSchools">去查院校</view>
    </view>

    <view class="school-list" wx:else>
      <view class="school-row" wx:for="{{list}}" wx:key="favoriteId || schoolId" data-id="{{item.schoolId}}" bindtap="goSchool">
        <view class="school-info">
          <text class="school-name">{{item.schoolName}}</text>
          <view class="school-meta">
            <text>{{item.province || ''}}{{item.city ? ' · ' + item.city : ''}}</text>
            <text wx:if="{{item.category}}"> · {{item.category}}</text>
          </view>
          <view class="school-tags" wx:if="{{item.tags && item.tags.length}}">
            <view wx:for="{{item.tags}}" wx:key="this" class="tag {{item === '985' ? 'tag-danger' : item === '211' ? 'tag-warning' : 'tag-info'}}">{{item}}</view>
          </view>
        </view>
        <view class="school-action">
          <view class="remove-btn" data-id="{{item.schoolId}}" catchtap="handleRemove">♥</view>
        </view>
      </view>
    </view>

    <view class="pagination" wx:if="{{total > size}}">
      <view class="load-more" bindtap="loadMore">加载更多</view>
      <text class="page-info">已加载 {{list.length}} / {{total}} 所</text>
    </view>
  </view>

  <!-- Loading -->
  <view class="loading-mask" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>
</view>
