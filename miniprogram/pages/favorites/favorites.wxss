.favorites-page {
  padding: 24rpx;
  min-height: 100vh;
}

.page-header {
  margin-bottom: 20rpx;
}

.page-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  display: block;
}

.page-subtitle {
  font-size: 24rpx;
  color: var(--text-muted);
  display: block;
  margin-top: 8rpx;
}

.list-wrap {
  min-height: 300rpx;
}

.school-list {
  background: var(--surface-color);
  border-radius: 20rpx;
  border: 1px solid var(--card-border);
  overflow: hidden;
}

.school-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 24rpx;
  border-bottom: 1px solid var(--card-border);
}

.school-row:last-child {
  border-bottom: none;
}

.school-row:active {
  background: rgba(102, 126, 234, 0.05);
}

.school-info {
  flex: 1;
  min-width: 0;
}

.school-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  margin-bottom: 8rpx;
}

.school-meta {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-bottom: 10rpx;
}

.school-tags {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
}

.school-action {
  flex-shrink: 0;
  margin-left: 20rpx;
}

.remove-btn {
  font-size: 40rpx;
  color: #f56c6c;
  padding: 8rpx;
}

.pagination {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 0;
}

.load-more {
  padding: 16rpx 48rpx;
  border-radius: 12rpx;
  background: var(--surface-color);
  color: var(--primary-color);
  font-size: 26rpx;
  border: 1px solid rgba(102, 126, 234, 0.3);
  margin-bottom: 12rpx;
}

.page-info {
  font-size: 22rpx;
  color: var(--text-muted);
}
