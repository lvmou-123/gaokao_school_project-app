.detail-page {
  padding: 24rpx;
  min-height: 100vh;
}

.info-card {
  background: var(--surface-color);
  border-radius: 20rpx;
  padding: 32rpx;
  border: 1px solid var(--card-border);
  margin-bottom: 16rpx;
}

.info-header {
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1px solid rgba(255, 255, 255, 0.06);
}

.info-title-group {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-wrap: wrap;
  margin-bottom: 12rpx;
}

.school-name {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.header-tags {
  display: flex;
  gap: 8rpx;
}

.info-code {
  font-size: 24rpx;
  color: var(--text-muted);
}

.info-grid {
  display: grid;
  gap: 20rpx;
}

.info-item {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.info-full {
  grid-column: 1 / -1;
}

.info-label {
  font-size: 22rpx;
  color: var(--text-muted);
}

.info-value {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.info-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

/* Sections */
.section-card {
  background: var(--surface-color);
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  border: 1px solid var(--card-border);
  margin-bottom: 16rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.section-count {
  font-size: 24rpx;
  color: var(--text-muted);
}

/* Major Table */
.major-table {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.major-row {
  background: rgba(255, 255, 255, 0.03);
  border-radius: 12rpx;
  padding: 20rpx;
  border: 1px solid rgba(255, 255, 255, 0.06);
}

.major-row-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.major-row-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.major-row-code {
  font-size: 22rpx;
  color: var(--text-muted);
}

.major-row-meta {
  display: flex;
  gap: 16rpx;
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

.major-row-desc {
  font-size: 22rpx;
  color: var(--text-muted);
  line-height: 1.5;
}

/* Recommendations */
.recommend-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.recommend-item {
  background: rgba(255, 255, 255, 0.03);
  border-radius: 16rpx;
  padding: 24rpx;
  border: 1px solid rgba(255, 255, 255, 0.06);
}

.recommend-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.recommend-school {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.recommend-reason {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  display: block;
  margin-bottom: 8rpx;
}

.recommend-major {
  font-size: 22rpx;
  color: var(--text-muted);
  display: block;
}
