.majors-page {
  padding: 24rpx;
  min-height: 100vh;
}

.list-wrap {
  min-height: 300rpx;
}

.major-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.major-card {
  background: var(--surface-color);
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  border: 1px solid var(--card-border);
}

.major-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.major-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.major-code {
  font-size: 24rpx;
  color: var(--text-muted);
}

.major-meta {
  display: flex;
  gap: 20rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}

.major-desc {
  font-size: 24rpx;
  color: var(--text-muted);
  line-height: 1.5;
  margin-bottom: 16rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.major-action {
  font-size: 26rpx;
  color: var(--primary-color);
  padding: 12rpx 0;
}

.pagination {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 0;
}

.load-more {
  padding: 16rpx 48rpx;
  border-radius: 12rpx;
  background: var(--surface-color);
  color: var(--primary-color);
  font-size: 26rpx;
  border: 1px solid rgba(102, 126, 234, 0.3);
  margin-bottom: 12rpx;
}

.page-info {
  font-size: 22rpx;
  color: var(--text-muted);
}
