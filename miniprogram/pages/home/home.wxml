<!-- Login Overlay -->
<view class="login-overlay" wx:if="{{!isLoggedIn}}">
  <view class="login-container">
    <view class="bg-shapes">
      <view class="shape shape-1"></view>
      <view class="shape shape-2"></view>
      <view class="shape shape-3"></view>
      <view class="shape shape-4"></view>
    </view>
    <view class="login-card">
      <view class="card-logo">🎓</view>
      <text class="card-title">高考志愿填报助手</text>
      <text class="card-subtitle">一键登录，开启智能志愿填报</text>
      <button class="wechat-login-btn" open-type="getPhoneNumber" bindgetphonenumber="onGetPhoneNumber" loading="{{logging}}">
        {{logging ? '登录中...' : '微信手机号一键登录'}}
      </button>
      <text class="card-agreement">登录即表示同意《用户协议》和《隐私政策》</text>
    </view>
  </view>
</view>

<!-- Main Content -->
<view class="poster-page" wx:else>
  <!-- Hero -->
  <view class="hero">
    <view class="hero-bg">
      <view class="hero-circle hero-circle-1"></view>
      <view class="hero-circle hero-circle-2"></view>
      <view class="hero-circle hero-circle-3"></view>
    </view>
    <view class="hero-content">
      <view class="hero-badge">🎯 2026 高考志愿填报</view>
      <view class="hero-title">
        选对方向
        <text class="hero-gradient">成就未来</text>
      </view>
      <view class="hero-subtitle">智能查询院校专业信息，AI 辅助志愿填报决策</view>
      <view class="hero-actions">
        <view class="hero-btn primary" bindtap="goSchools">开始查询</view>
        <view class="hero-btn default" bindtap="goAiChat">AI 咨询</view>
      </view>
    </view>
  </view>

  <!-- Feature Cards -->
  <view class="features">
    <view class="feature-card" data-path="/pages/schools/schools" bindtap="goPage">
      <view class="feature-icon" style="background: #667eea">🏛</view>
      <text class="feature-title">查院校</text>
      <text class="feature-desc">全国高校信息查询</text>
      <view class="feature-arrow">→</view>
    </view>
    <view class="feature-card" data-path="/pages/majors/majors" bindtap="goPage">
      <view class="feature-icon" style="background: #764ba2">📚</view>
      <text class="feature-title">查专业</text>
      <text class="feature-desc">专业目录与详情</text>
      <view class="feature-arrow">→</view>
    </view>
    <view class="feature-card" data-path="/pages/ai-chat/ai-chat" bindtap="goPage">
      <view class="feature-icon" style="background: #f093fb">🤖</view>
      <text class="feature-title">AI 助手</text>
      <text class="feature-desc">智能填报咨询</text>
      <view class="feature-arrow">→</view>
    </view>
  </view>

  <!-- Stats -->
  <view class="info">
    <view class="info-card">
      <view class="info-number">2800+</view>
      <view class="info-label">全国院校</view>
    </view>
    <view class="info-card">
      <view class="info-number">700+</view>
      <view class="info-label">本科专业</view>
    </view>
    <view class="info-card">
      <view class="info-number">AI</view>
      <view class="info-label">智能推荐</view>
    </view>
  </view>
</view>
