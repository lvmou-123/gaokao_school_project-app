.chat-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

.score-card {
  background: var(--surface-color);
  padding: 24rpx;
  border-bottom: 1px solid var(--card-border);
}

.score-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.score-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  width: 80rpx;
  flex-shrink: 0;
}

.score-input {
  flex: 1;
  background: rgba(255, 255, 255, 0.06);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  color: var(--text-primary);
  font-size: 26rpx;
}

.score-actions {
  display: flex;
  justify-content: flex-end;
}

.chat-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  background: var(--surface-color);
}

.chat-messages {
  flex: 1;
  padding: 24rpx;
  background: rgba(0, 0, 0, 0.15);
  max-height: calc(100vh - 300rpx);
}

.message {
  margin-bottom: 24rpx;
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.message-user {
  justify-content: flex-end;
}

.message-user .bubble {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  border-radius: 16rpx 4rpx 16rpx 16rpx;
  order: 1;
}

.message-assistant {
  justify-content: flex-start;
}

.message-assistant .bubble {
  background: var(--surface-color);
  color: var(--text-primary);
  border-radius: 4rpx 16rpx 16rpx 16rpx;
  border: 1px solid rgba(255, 255, 255, 0.08);
}

.bubble {
  max-width: 75%;
  padding: 20rpx 28rpx;
  line-height: 1.6;
  font-size: 28rpx;
  white-space: pre-wrap;
  word-break: break-word;
}

.avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  flex-shrink: 0;
}

.avatar-ai {
  background: #f0f2ff;
}

.avatar-user {
  background: rgba(102, 126, 234, 0.1);
  order: 2;
}

.chat-input-area {
  padding: 16rpx 24rpx;
  border-top: 1px solid rgba(255, 255, 255, 0.06);
  background: var(--surface-color);
}

.score-toggle {
  font-size: 22rpx;
  color: var(--primary-color);
  margin-bottom: 12rpx;
  display: inline-block;
}

.input-row {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.msg-input {
  flex: 1;
  background: rgba(255, 255, 255, 0.06);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  color: var(--text-primary);
  font-size: 28rpx;
  min-height: 80rpx;
}

.send-btn {
  padding: 16rpx 32rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.4);
  background: rgba(255, 255, 255, 0.06);
}

.send-btn.active {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
}
