.schools-page {
  padding: 24rpx;
  min-height: 100vh;
}

.list-wrap {
  min-height: 300rpx;
}

.school-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.school-card {
  background: var(--surface-color);
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  border: 1px solid var(--card-border);
}

.school-card:active {
  transform: translateY(-4rpx);
  box-shadow: 0 12rpx 32rpx rgba(102, 126, 234, 0.15);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.school-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.favorite-btn {
  font-size: 40rpx;
  color: var(--text-muted);
  padding: 8rpx;
}

.favorite-btn.active {
  color: #f56c6c;
}

.card-tags {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
  margin-bottom: 16rpx;
}

.card-meta {
  display: flex;
  gap: 24rpx;
  font-size: 24rpx;
  color: var(--text-muted);
}

.pagination {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 0;
}

.load-more {
  padding: 16rpx 48rpx;
  border-radius: 12rpx;
  background: var(--surface-color);
  color: var(--primary-color);
  font-size: 26rpx;
  border: 1px solid rgba(102, 126, 234, 0.3);
  margin-bottom: 12rpx;
}

.page-info {
  font-size: 22rpx;
  color: var(--text-muted);
}
