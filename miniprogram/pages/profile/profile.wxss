.profile-page {
  padding: 32rpx 24rpx;
  min-height: 100vh;
}

/* Login Prompt */
.login-prompt {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx;
  background: var(--surface-color);
  border-radius: 24rpx;
  border: 1px solid var(--card-border);
}

.prompt-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  margin-bottom: 24rpx;
}

.prompt-text {
  font-size: 28rpx;
  color: var(--text-muted);
  margin-bottom: 40rpx;
}

.wechat-login-btn {
  width: 480rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: linear-gradient(135deg, #07c160, #06ad56);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 44rpx;
  border: none;
  padding: 0;
}

.wechat-login-btn::after {
  border: none;
}

.wechat-login-btn:active {
  opacity: 0.9;
}

/* User Card */
.user-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 32rpx;
  background: var(--surface-color);
  border-radius: 24rpx;
  border: 1px solid var(--card-border);
  margin-bottom: 24rpx;
}

.user-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea, #764ba2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #fff;
  font-weight: 700;
}

.user-info {
  flex: 1;
}

.user-name {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
  display: block;
  margin-bottom: 6rpx;
}

.user-phone {
  font-size: 24rpx;
  color: var(--text-muted);
}

/* Menu */
.menu-list {
  background: var(--surface-color);
  border-radius: 20rpx;
  border: 1px solid var(--card-border);
  overflow: hidden;
  margin-bottom: 32rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx 24rpx;
  border-bottom: 1px solid var(--card-border);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: rgba(255, 255, 255, 0.03);
}

.menu-icon {
  font-size: 32rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: var(--text-primary);
}

.menu-arrow {
  font-size: 28rpx;
  color: var(--text-muted);
}

/* Logout */
.logout-btn {
  text-align: center;
  padding: 28rpx;
  background: var(--surface-color);
  border-radius: 20rpx;
  border: 1px solid var(--card-border);
  color: #f56c6c;
  font-size: 28rpx;
  margin-bottom: 32rpx;
}

.logout-btn:active {
  background: rgba(245, 108, 108, 0.05);
}

/* Version */
.version {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: var(--text-muted);
}
