<view class="profile-page">
  <!-- Not Logged In -->
  <view class="login-prompt" wx:if="{{!isLoggedIn}}">
    <view class="prompt-avatar">👤</view>
    <text class="prompt-text">使用微信手机号一键登录</text>
    <button class="wechat-login-btn" open-type="getPhoneNumber" bindgetphonenumber="onGetPhoneNumber" loading="{{logging}}">
      {{logging ? '登录中...' : '微信手机号一键登录'}}
    </button>
  </view>

  <!-- Logged In -->
  <view class="profile-content" wx:else>
    <view class="user-card">
      <view class="user-avatar">{{userInfo.nickname ? userInfo.nickname[0] : '👤'}}</view>
      <view class="user-info">
        <text class="user-name">{{userInfo.nickname || '微信用户'}}</text>
        <text class="user-phone" wx:if="{{userInfo.phone}}">已绑定手机号</text>
      </view>
    </view>

    <view class="menu-list">
      <view class="menu-item" bindtap="goFavorites">
        <text class="menu-icon">❤️</text>
        <text class="menu-text">我的收藏</text>
        <text class="menu-arrow">→</text>
      </view>
      <view class="menu-item" bindtap="goAiChat">
        <text class="menu-icon">🤖</text>
        <text class="menu-text">AI 助手</text>
        <text class="menu-arrow">→</text>
      </view>
      <view class="menu-item" bindtap="goSchools">
        <text class="menu-icon">🏛</text>
        <text class="menu-text">查院校</text>
        <text class="menu-arrow">→</text>
      </view>
      <view class="menu-item" bindtap="goMajors">
        <text class="menu-icon">📚</text>
        <text class="menu-text">查专业</text>
        <text class="menu-arrow">→</text>
      </view>
    </view>

    <view class="logout-btn" bindtap="handleLogout">退出登录</view>
  </view>

  <text class="version">v1.0.0</text>
</view>
